<idea-plugin>
    <id>com.perfmonitor</id>
    <name>Perf Monitor</name>
    <vendor>Your Name</vendor>
    <description><![CDATA[
        Performance monitoring plugin for Android apps.
        Captures Memory, CPU, Network, Battery and UI rendering
        sessions and analyses them with GitHub Copilot.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                factoryClass="com.perfmonitor.toolWindow.PerfToolWindowFactory"
                id="Perf Monitor"
                anchor="bottom"
                canCloseContents="false"
                secondary="false"/>
        <postStartupActivity
                implementation="com.perfmonitor.startup.PerfMonitorActivity"/>
    </extensions>

</idea-plugin>